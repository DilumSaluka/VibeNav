<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/alert_red">

    <ImageView
        android:id="@+id/alertIcon"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/ic_vibration"
        android:layout_marginTop="80dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:contentDescription="Alert" />

    <TextView
        android:id="@+id/alertTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/alert_title"
        android:textColor="@android:color/white"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/alertIcon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:paddingHorizontal="32dp" />

    <TextView
        android:id="@+id/alertMessage"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/alert_message"
        android:textColor="@android:color/white"
        android:textSize="18sp"
        android:textAlignment="center"
        android:layout_marginTop="16dp"
        android:alpha="0.9"
        app:layout_constraintTop_toBottomOf="@id/alertTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:paddingHorizontal="32dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/dismissButton"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="Silence Alarm"
        android:textSize="16sp"
        app:cornerRadius="28dp"
        android:layout_marginTop="48dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintTop_toBottomOf="@id/alertMessage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/stopMissionButton"
        app:backgroundTint="@android:color/white"
        android:textColor="@color/alert_red" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/stopMissionButton"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="Stop Mission"
        android:textSize="16sp"
        app:cornerRadius="28dp"
        android:layout_marginStart="8dp"
        app:layout_constraintTop_toTopOf="@id/dismissButton"
        app:layout_constraintStart_toEndOf="@id/dismissButton"
        app:layout_constraintEnd_toEndOf="parent"
        app:backgroundTint="#FF4444"
        android:textColor="@android:color/white" />

</androidx.constraintlayout.widget.ConstraintLayout>
