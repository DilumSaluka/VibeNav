<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/navy_dark">

    <TextView
        android:id="@+id/skipText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Skip"
        android:textColor="#555577"
        android:textSize="14sp"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tutorialIcon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="72sp"
        android:layout_marginTop="80dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tutorialTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
            android:textColor="@color/on_navy_dark"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:layout_marginTop="28dp"
        android:layout_marginHorizontal="40dp"
        app:layout_constraintTop_toBottomOf="@id/tutorialIcon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tutorialDesc"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:textColor="#AAAAAA"
        android:textSize="17sp"
        android:textAlignment="center"
        android:lineSpacingExtra="8dp"
        android:gravity="center"
        android:layout_marginTop="16dp"
        android:layout_marginHorizontal="40dp"
        app:layout_constraintTop_toBottomOf="@id/tutorialTitle"
        app:layout_constraintBottom_toTopOf="@id/dotIndicator"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/dotIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintBottom_toTopOf="@id/navRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="24dp" />

    <LinearLayout
        android:id="@+id/navRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/prevButton"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:text="Back"
            android:textSize="15sp"
            android:textColor="#999999"
            app:cornerRadius="26dp"
            android:paddingHorizontal="28dp"
            android:visibility="invisible"
            app:backgroundTint="#2A2A4A"
            app:strokeColor="#444466"
            app:strokeWidth="1dp" />

        <TextView
            android:id="@+id/counterText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="#555577"
            android:textSize="14sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/nextButton"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:text="Next"
            android:textSize="15sp"
        android:textColor="@color/on_navy_dark"
            app:cornerRadius="26dp"
            android:paddingHorizontal="36dp"
            app:backgroundTint="@color/accent_blue" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
